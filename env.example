# Moss semantic retrieval — get credentials at https://portal.usemoss.dev
MOSS_PROJECT_ID=your_moss_project_id
MOSS_PROJECT_KEY=your_moss_project_key
# Name you choose for your knowledge-base index. create-index.py creates it,
# bot.py queries it — the two must match.
MOSS_INDEX_NAME=receptionist_kb

# Optional retrieval tuning (defaults shown)
# MOSS_TOP_K=5      # how many docs to inject into the LLM context per turn
# MOSS_ALPHA=0.8    # 1.0 = pure semantic, 0.0 = pure keyword

# Speech-to-text — https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# LLM — https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4

# Text-to-speech — https://play.cartesia.ai
CARTESIA_API_KEY=your_cartesia_api_key
